# Kira Pay Configuration
# For cross-chain payment integration

# Kira Pay API Key
# Get this from: https://dashboard.kira-pay.com/api-keys
# Used for creating payment links and managing webhooks
KIRA_PAY_API_KEY=your_kira_pay_api_key_here

# Backend Webhook URL
# This is where Kira Pay will send payment confirmations
# The off-chain node will listen to these webhooks to process payments
# Format: https://your-backend.com/api/webhooks/kira-pay
KIRA_PAY_WEBHOOK_URL=https://your-backend.com/api/webhooks/kira-pay

# Backend Node Address
# The Solana address of your off-chain backend node
# This node will receive cross-chain payments and deposit them on behalf of users
# Add this after your backend is deployed
KIRA_PAY_BACKEND_WALLET=your_backend_wallet_address_here

# Supported Currencies for Cross-Chain Payments
# Default: USDC,USDT,PUSD
KIRA_PAY_SUPPORTED_CURRENCIES=USDC,USDT,PUSD
