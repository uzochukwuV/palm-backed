# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Solana Configuration
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_PROGRAM_ID=3bvDjnbgsJdsFHRGzzwZVn5maCmEhkBKr7mF2Y7aFCwi
NEXT_PUBLIC_SOLANA_RPC_DEVNET=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_RPC_MAINNET=https://api.mainnet-beta.solana.com

# Relay Wallet (SECURITY WARNING: Use KMS in production!)
# Generate with: solana-keygen new --outfile relay-wallet.json
# Convert to base58: cat relay-wallet.json | jq -r '.[0:32] | @base64' | base64 -d | base58
RELAY_WALLET_PRIVATE_KEY=your_base58_encoded_private_key

# Application URL (for webhooks and redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# KiraPay Configuration (optional - for cross-chain payments)
KIRA_PAY_API_KEY=your_kira_pay_api_key
KIRA_PAY_API_URL=https://api.kirapay.io
KIRA_PAY_WEBHOOK_SECRET=your_webhook_secret